{% extends 'base.html.twig' %}

{% block title %}Formation Claude IA pour Consultants & Formateurs Solo{% endblock %}
{% block titleSuffix %} | Instant IA{% endblock %}
{% block description %}La méthode pas-à-pas pour transformer Claude en ton bras droit en 14 jours. Pour consultants, formateurs et solopreneurs non-tech. Garantie 14j.{% endblock %}

{# On override le header par défaut de base.html.twig pour la home —
   le header reste le même, mais on garde la possibilité de switch vers
   une version "scrolled" sur la home (à venir Sprint 2.x). #}

{% block body %}

{# ════════════════════════════════════════════════════════════════
   SECTION 1 — HERO scroll-driving (sticky 200vh)
   ════════════════════════════════════════════════════════════════ #}
<section class="hero-sticky" data-controller="hero-scroll">
    <div class="hero-sticky-inner">
        <div class="hero-grid-bg"></div>
        <div class="hero-glow" data-hero-scroll-target="glow"></div>

        <div class="hero-content-driven" data-hero-scroll-target="content">
            <div class="eyebrow-ds" style="color: var(--color-gold-300);">Formation · 14 jours · Pour solos</div>

            <h1 style="font-family: var(--font-display); font-weight: 400; font-size: clamp(3rem, 7.5vw, 6.4rem); line-height: 1.02; letter-spacing: var(--tracking-tightest); margin: 0 0 1.5rem; color: var(--color-paper);">
                Transforme Claude<br>
                en ton <em style="font-style: italic; color: var(--color-gold-300);">bras droit.</em>
            </h1>

            <p style="font-size: var(--text-lg); color: rgba(255,255,255,0.7); line-height: var(--leading-relaxed); max-width: 56ch; margin: 0 auto 2.5rem;">
                En 14 jours, tu construis tes 3 Agents IA, tu maîtrises la méthode P.R.O.M.P.T. et tu récupères 9 à 12 heures par semaine. Sans coder.
            </p>

            <div class="flex flex-wrap items-center justify-center gap-3">
                <a href="/formation-claude-consultant" class="inline-flex items-center gap-2 rounded-pill bg-gold-400 px-7 py-4 font-medium text-ink-700 shadow-glow-gold transition hover:bg-gold-300 hover:-translate-y-0.5">
                    <span>Je découvre la formation</span>
                    <span aria-hidden="true">→</span>
                </a>
                <a href="/3-agents-ia-gratuits" class="inline-flex items-center gap-2 rounded-pill border border-paper/40 px-7 py-4 font-medium text-paper transition hover:border-paper hover:bg-paper/5">
                    <span>3 Agents gratuits</span>
                </a>
            </div>
        </div>

        <div class="scroll-cue" data-hero-scroll-target="cue" aria-hidden="true">
            <span>Scroll</span>
            <div class="cue-line"></div>
        </div>
    </div>
</section>

{# ════════════════════════════════════════════════════════════════
   SECTION 2 — MARQUEE STRIP (font-display + étoiles gold)
   ════════════════════════════════════════════════════════════════ #}
<div class="marquee-strip" data-controller="marquee" aria-hidden="true">
    <div class="marquee-strip-track" data-marquee-target="track">
        <span class="marquee-strip-item">9-12h <em>récupérées par semaine</em></span>
        <span class="marquee-strip-star">★</span>
        <span class="marquee-strip-item">3 Agents <em>opérationnels</em></span>
        <span class="marquee-strip-star">★</span>
        <span class="marquee-strip-item">Méthode P.R.O.M.P.T.</span>
        <span class="marquee-strip-star">★</span>
        <span class="marquee-strip-item">147€ <em>early-bird</em></span>
        <span class="marquee-strip-star">★</span>
        <span class="marquee-strip-item">Garantie <em>14 jours</em></span>
        <span class="marquee-strip-star">★</span>
    </div>
</div>

{# ════════════════════════════════════════════════════════════════
   SECTION 3 — INTRO + STATS BAR
   ════════════════════════════════════════════════════════════════ #}
<section style="padding: 8rem 2.5rem;">
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: end; max-width: 1240px; margin: 0 auto;" class="intro-grid">
        <div class="reveal-left">
            <div class="eyebrow-ds">À propos · Rama</div>
            <h2 class="section-title-ds split" data-controller="split-text">
                Pour les solos qui veulent <em>scaler</em>.<br>Sans recruter.
            </h2>
            <span class="rule-draw" style="max-width: 280px; margin-top: 1.5rem;"></span>
        </div>
        <div class="reveal-right delay-2">
            <p style="font-size: var(--text-lg); color: var(--fg-muted); line-height: var(--leading-relaxed); max-width: 56ch;">
                Je suis Rama Soumaré, formatrice IA. Depuis 2 ans, j'aide les consultants, formateurs et coachs solo non-tech à intégrer Claude dans leur quotidien. Pas avec des promesses floues — avec des prompts, des agents, des workflows qui tournent.
            </p>
            <p style="font-size: var(--text-lg); color: var(--fg-muted); line-height: var(--leading-relaxed); margin-top: 1rem;">
                <span style="color: var(--color-gold-500); font-style: italic; font-family: var(--font-display); font-size: var(--text-xl);">Pas de blabla. Que de l'action.</span>
            </p>
        </div>
    </div>

    <div class="stats-bar" style="max-width: 1240px; margin-left: auto; margin-right: auto;">
        <div class="stat reveal">
            <span class="stat-num"
                  data-controller="counter-animation"
                  data-counter-animation-target-value="150"
                  data-counter-animation-suffix-value="+">+0</span>
            <div class="stat-label">[PLACEHOLDER] Élèves accompagnés</div>
            <p class="stat-helper">Solopreneurs qui ont intégré Claude dans leur quotidien.</p>
        </div>
        <div class="stat reveal delay-2">
            <span class="stat-num"
                  data-controller="counter-animation"
                  data-counter-animation-target-value="11"
                  data-counter-animation-suffix-value="h">0h</span>
            <div class="stat-label">Gagnées / semaine</div>
            <p class="stat-helper">Moyenne après 14 jours d'application des 3 Agents.</p>
        </div>
        <div class="stat reveal delay-3">
            <span class="stat-num"
                  data-controller="counter-animation"
                  data-counter-animation-target-value="98"
                  data-counter-animation-suffix-value="%">0%</span>
            <div class="stat-label">[PLACEHOLDER] Recommandent</div>
            <p class="stat-helper">À un confrère, sur les avis post-formation.</p>
        </div>
    </div>
</section>

{# ════════════════════════════════════════════════════════════════
   SECTION 4 — PILLARS (scroll-pin avec 3 méthodes)
   ════════════════════════════════════════════════════════════════ #}
<section style="background: var(--color-cream-200); padding: 8rem 2.5rem;" data-controller="pillars-pin">
    <div class="reveal" style="max-width: 1240px; margin: 0 auto 2.5rem;">
        <div class="eyebrow-ds">Méthode · 3 piliers</div>
        <h2 class="section-title-ds split" data-controller="split-text">
            Trois façons de <em>bosser</em> ensemble.
        </h2>
        <span class="rule-draw" style="max-width: 200px; margin-top: 1.5rem;"></span>
    </div>

    <div style="display: grid; grid-template-columns: 1.2fr 1fr; gap: 4rem; max-width: 1240px; margin: 0 auto; align-items: start;" class="pillars-grid">
        <div style="display: flex; flex-direction: column; gap: 1rem;">
            <div class="pillar active reveal" data-pillars-pin-target="pillar" role="button" tabindex="0" aria-pressed="true">
                <div class="pillar-top">
                    <span class="pillar-num">01</span>
                    <h3 class="pillar-title">Le <em>Système Claude</em></h3>
                    <div class="pillar-arrow">→</div>
                </div>
                <p class="pillar-desc">Formation Niveau 1 en 14 jours. Tu construis tes 3 Agents (Inbox, Mission, Propal), tu maîtrises la méthode P.R.O.M.P.T. À 147€ early-bird, garantie 14 jours.</p>
            </div>
            <div class="pillar reveal delay-2" data-pillars-pin-target="pillar">
                <div class="pillar-top">
                    <span class="pillar-num">02</span>
                    <h3 class="pillar-title">L'audit <em>IA personnalisé</em></h3>
                    <div class="pillar-arrow">→</div>
                </div>
                <p class="pillar-desc">1h en visio. On analyse tes process, tes outils, ton workflow — et je te montre où Claude peut te faire gagner du temps. Plan d'action 30/60/90 jours.</p>
            </div>
            <div class="pillar reveal delay-3" data-pillars-pin-target="pillar">
                <div class="pillar-top">
                    <span class="pillar-num">03</span>
                    <h3 class="pillar-title">Le <em>Consulting</em></h3>
                    <div class="pillar-arrow">→</div>
                </div>
                <p class="pillar-desc">Done-with-you. Je construis tes Agents avec toi, je te forme, je te branche sur tes outils. Comme une cofondatrice tech à tes côtés.</p>
            </div>
        </div>

        <div class="pillars-visual">
            <div class="pillars-frame active" data-pillars-pin-target="frame">
                <div>
                    <div class="pillars-frame-art">Le<br><em>Système</em><br>Claude</div>
                    <div class="pillars-frame-meta"><span><b>14</b> jours</span><span><b>27</b> vidéos</span><span><b>147€</b></span></div>
                </div>
            </div>
            <div class="pillars-frame" data-pillars-pin-target="frame">
                <div>
                    <div class="pillars-frame-art"><em>L'audit</em><br>Express</div>
                    <div class="pillars-frame-meta"><span><b>1h</b></span><span><b>1 visio</b></span><span><b>497€</b></span></div>
                </div>
            </div>
            <div class="pillars-frame" data-pillars-pin-target="frame">
                <div>
                    <div class="pillars-frame-art">Le<br><em>Consulting</em></div>
                    <div class="pillars-frame-meta"><span><b>3 mois</b></span><span><b>Sur-mesure</b></span><span><b>1 500€+</b></span></div>
                </div>
            </div>
        </div>
    </div>
</section>

{# ════════════════════════════════════════════════════════════════
   SECTION 5 — OFFERS (cards parallax)
   ════════════════════════════════════════════════════════════════ #}
<section style="padding: 8rem 2.5rem; max-width: 1240px; margin: 0 auto;">
    <div class="reveal">
        <div class="eyebrow-ds">Offres · disponibles</div>
        <h2 class="section-title-ds split" data-controller="split-text">
            Au prix juste,<br><em>tout de suite.</em>
        </h2>
        <span class="rule-draw" style="max-width: 200px; margin-top: 1.5rem;"></span>
    </div>

    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-top: 2.5rem;" class="offers-grid">
        <article class="offer-card-ds reveal delay-1"
                 data-controller="parallax-element"
                 data-parallax-element-strength-value="-30">
            <span class="badge-card">Best-seller</span>
            <div class="price-art">147€<small>· 30 places early-bird</small></div>
            <h3>Le <em>Système</em><br>Claude du Consultant</h3>
            <p>Formation 14 jours, 27 vidéos, 3 Agents construits, méthode P.R.O.M.P.T. Garantie 14 jours satisfait ou remboursé.</p>
            <a class="cta" href="/formation-claude-consultant">Découvrir →</a>
        </article>

        <article class="offer-card-ds featured reveal delay-2"
                 data-controller="parallax-element"
                 data-parallax-element-strength-value="30">
            <span class="badge-card">Premium</span>
            <div class="price-art">497€<small>· 1h visio + suivi 30j</small></div>
            <h3>L'audit <em>IA</em><br>personnalisé</h3>
            <p>Diagnostic complet de tes process, 3 cas d'usage IA prioritaires, plan d'action 30/60/90 jours. Déduit du consulting si tu enchaînes.</p>
            <a class="cta" href="/audit-ia">Réserver →</a>
        </article>

        <article class="offer-card-ds reveal delay-3"
                 data-controller="parallax-element"
                 data-parallax-element-strength-value="-15">
            <div class="price-art">1 500€<small>· à partir de</small></div>
            <h3>Le <em>Consulting</em><br>done-with-you</h3>
            <p>Je construis tes Agents avec toi, je te forme, je te branche sur tes outils. Sur-mesure, devis selon scope.</p>
            <a class="cta" href="/consulting">Discuter →</a>
        </article>
    </div>
</section>

{# ════════════════════════════════════════════════════════════════
   SECTION 6 — BIG QUOTE
   ════════════════════════════════════════════════════════════════ #}
<section class="quote-section">
    <div style="max-width: 1240px; margin: 0 auto;">
        <div class="eyebrow-ds reveal" style="color: var(--color-gold-300);">★ ★ ★ ★ ★ · témoignage vérifié</div>
        <blockquote class="big-q split reveal delay-1" data-controller="split-text">
            « Grâce à Rama, j'ai automatisé 80% de ma création de contenu. Je gagne <em>15h par semaine.</em> Concrètement. »
        </blockquote>
        <span class="rule-draw reveal" style="max-width: 480px; background: var(--color-gold-300); margin-bottom: 1.5rem;"></span>
        <div class="author reveal delay-2">
            <div class="avatar-q">S</div>
            <div>
                <div style="color: var(--color-paper); font-size: var(--text-md); font-weight: 600;">Sophie M.</div>
                <div style="font-family: var(--font-mono); font-size: var(--text-2xs); text-transform: uppercase; letter-spacing: var(--tracking-wider); color: rgba(255,255,255,0.5);">Coach business</div>
            </div>
        </div>
    </div>
</section>

{# ════════════════════════════════════════════════════════════════
   SECTION 7 — FAQ
   ════════════════════════════════════════════════════════════════ #}
