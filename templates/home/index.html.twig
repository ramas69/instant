{% extends 'base.html.twig' %}

{% block title %}Formation Claude IA pour Consultants & Formateurs Solo{% endblock %}
{% block titleSuffix %} | Instant IA{% endblock %}
{% block description %}La méthode pas-à-pas pour transformer Claude en ton bras droit en 14 jours. Pour consultants, formateurs et solopreneurs non-tech. Garantie 14j.{% endblock %}

{% block body %}

{# ════════════════════════════════════════════════════════════════
   SECTION 1 — HERO KINETIC (exception documentée du DS — dark + grid)
   ════════════════════════════════════════════════════════════════ #}
<section class="hero-kinetic" id="top">
    <div class="hero-kinetic-content">
        <div class="hero-kinetic-grid hero-kinetic-grid--centered">

            <div class="hero-kinetic-left">
                <p class="eyebrow-ds" style="color: var(--color-gold-300);">
                    Formation pour consultants &amp; formateurs solo
                </p>

                <h1 class="hero-kinetic-headline">
                    Transforme Claude en ton <em>bras droit</em><br>
                    en 14 jours.
                </h1>

                <p class="hero-kinetic-sub">
                    La méthode <strong>pas-à-pas</strong> pour récupérer <strong>10h/semaine</strong>.
                    <span class="dim">Sans coder, sans 200 prompts à apprendre.</span>
                </p>

                <div class="hero-kinetic-actions">
                    <a href="/formation-claude-consultant"
                       data-controller="magnetic-button"
                       class="hero-kinetic-btn hero-kinetic-btn--primary">
                        Je veux mon Système Claude <span aria-hidden="true">→</span>
                    </a>
                    <a href="#lead-magnet" class="hero-kinetic-link">
                        Découvre 3 Agents IA gratuits <span aria-hidden="true">↓</span>
                    </a>
                </div>

                <ul class="hero-kinetic-badges" aria-label="Garanties de la formation">
                    <li><span aria-hidden="true">⭐</span> 4,9/5</li>
                    <li><span aria-hidden="true">🎁</span> 14j satisfait/remboursé</li>
                    <li><span aria-hidden="true">🇫🇷</span> 100% en français</li>
                    <li><span aria-hidden="true">📱</span> Vidéos courtes 3-5 min</li>
                </ul>
            </div>

        </div>
    </div>
</section>

{# ════════════════════════════════════════════════════════════════
   SECTION 2 — INTRO RAMA (sans stats placeholder — 3 trust points honnêtes)
   ════════════════════════════════════════════════════════════════ #}
<section class="relative overflow-hidden" style="padding: 8rem 2.5rem;">
    <span class="editorial-number left" aria-hidden="true">01</span>

    <div class="relative z-10" style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: end; max-width: 1240px; margin: 0 auto;">
        <div class="reveal-left intro-grid-left">
            <span class="deco-asterisk" aria-hidden="true">*</span>
            <div class="eyebrow-ds">À propos · Rama</div>
            <h2 class="section-title-ds split" data-controller="split-text">
                Pour les solos qui veulent <em>scaler</em>.<br>Sans recruter.
            </h2>
            <span class="rule-draw" style="max-width: 280px; margin-top: 1.5rem;"></span>
        </div>
        <div class="reveal-right delay-2 intro-grid-right">
            <p class="has-dropcap" style="font-size: var(--text-lg); color: var(--fg-muted); line-height: var(--leading-relaxed); max-width: 56ch;">
                Je suis Rama Soumaré, formatrice IA. Depuis 2 ans, j'aide les consultants, formateurs et coachs solo non-tech à intégrer Claude dans leur quotidien. Pas avec des promesses floues — avec des prompts, des agents, des workflows qui tournent.
            </p>
            <p style="font-size: var(--text-lg); color: var(--fg-muted); line-height: var(--leading-relaxed); margin-top: 1rem;">
                <span style="color: var(--color-gold-500); font-style: italic; font-family: var(--font-display); font-size: var(--text-xl);">Pas de blabla. Que de l'action.</span>
            </p>
        </div>
    </div>

    <div class="trust-row" style="max-width: 1240px; margin: 5rem auto 0; display: grid; grid-template-columns: repeat(3, 1fr); gap: 2.5rem;">
        <div class="trust-item reveal">
            <div class="trust-eyebrow">Tarif</div>
            <div class="trust-headline serif">147€ <em>early-bird</em></div>
            <p class="trust-helper">30 premières places. Puis 297€ catalogue.</p>
        </div>
        <div class="trust-item reveal delay-2">
            <div class="trust-eyebrow">Garantie</div>
            <div class="trust-headline serif">14 jours <em>sans condition</em></div>
            <p class="trust-helper">Tu m'écris avant J+14, je te rembourse. Pas de petites lignes.</p>
        </div>
        <div class="trust-item reveal delay-3">
            <div class="trust-eyebrow">Format</div>
            <div class="trust-headline serif">45 min <em>par jour</em></div>
            <p class="trust-helper">14 jours en mode sprint. Ou étalé — tu as accès à vie.</p>
        </div>
    </div>
</section>

{# ════════════════════════════════════════════════════════════════
   SECTION 3 — LES 3 AGENTS (mockups Claude, cœur narratif)
   ════════════════════════════════════════════════════════════════ #}
<section class="relative overflow-hidden bg-cream-50" style="padding: 8rem 2.5rem;">
    <div class="relative z-10" style="max-width: 1240px; margin: 0 auto;">
        <div class="reveal" style="margin-bottom: 4rem;">
            <span class="deco-asterisk" aria-hidden="true">*</span>
            <div class="eyebrow-ds">Les 3 Agents</div>
            <h2 class="section-title-ds split" data-controller="split-text">
                Trois agents qui <em>tournent</em><br>en arrière-plan.
            </h2>
            <span class="rule-draw" style="max-width: 200px; margin-top: 1.5rem;"></span>
        </div>

        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem;" class="agents-mockup-grid">

            {# Agent Inbox #}
            <div class="reveal">
                <div class="agent-mockup">
                    <div class="agent-mockup-window">
                        <span class="agent-mockup-dot"></span>
                        <span class="agent-mockup-dot"></span>
                        <span class="agent-mockup-dot"></span>
                        <span class="agent-mockup-url">claude.ai/projects/inbox</span>
                    </div>
                    <div class="agent-mockup-body">
                        <div class="agent-mockup-prompt">
                            Trie les emails reçus aujourd'hui et propose une réponse pour chaque.
                        </div>
                        <div class="agent-mockup-response">
                            <strong>3 emails urgents</strong> · 2 relances clients<br>
                            <strong>5 emails à classer</strong> sans urgence<br>
                            → 12 réponses pré-rédigées dispo
                        </div>
                    </div>
                </div>
                <div style="margin-top: 1.25rem;">
                    <p class="font-mono text-xs uppercase tracking-widest text-gold-500 mb-1">Agent 01</p>
                    <h3 class="serif text-2xl text-ink-900 mb-2">L'Agent Inbox</h3>
                    <p class="text-sm text-ink-300 leading-relaxed">
                        Tu ouvres Gmail, 80% du boulot est déjà fait. <em class="not-italic font-medium text-gold-500">4-5h/sem récupérées</em>.
                    </p>
                </div>
            </div>

            {# Agent Mission #}
            <div class="reveal delay-2">
                <div class="agent-mockup">
                    <div class="agent-mockup-window">
                        <span class="agent-mockup-dot"></span>
                        <span class="agent-mockup-dot"></span>
                        <span class="agent-mockup-dot"></span>
                        <span class="agent-mockup-url">claude.ai/projects/mission</span>
                    </div>
                    <div class="agent-mockup-body">
                        <div class="agent-mockup-prompt">
                            Voici la transcription de mon call client. Donne-moi un CR + plan d'action.
                        </div>
                        <div class="agent-mockup-response">
                            <strong>Compte-rendu</strong><br>
                            • 4 sujets discutés<br>
                            • 3 décisions actées<br>
                            <strong>Plan d'action</strong> · 7 tâches priorisées
                        </div>
                    </div>
                </div>
                <div style="margin-top: 1.25rem;">
                    <p class="font-mono text-xs uppercase tracking-widest text-gold-500 mb-1">Agent 02</p>
                    <h3 class="serif text-2xl text-ink-900 mb-2">L'Agent Mission</h3>
                    <p class="text-sm text-ink-300 leading-relaxed">
                        Sors d'un call avec ton CR déjà prêt. <em class="not-italic font-medium text-gold-500">3-4h/sem récupérées</em>.
                    </p>
                </div>
            </div>

            {# Agent Propal #}
            <div class="reveal delay-3">
                <div class="agent-mockup">
                    <div class="agent-mockup-window">
                        <span class="agent-mockup-dot"></span>
                        <span class="agent-mockup-dot"></span>
                        <span class="agent-mockup-dot"></span>
                        <span class="agent-mockup-url">claude.ai/projects/propal</span>
                    </div>
                    <div class="agent-mockup-body">
                        <div class="agent-mockup-prompt">
                            Client : Acme Corp · Scope : audit RH · Budget : 8K€. Génère la propal.
                        </div>
                        <div class="agent-mockup-response">
                            <strong>Propal_AcmeCorp.pdf</strong><br>
                            • 12 pages · branding adapté<br>
                            • Pricing · livrables · planning<br>
                            → prête en <strong>15 min</strong>
                        </div>
                    </div>
                </div>
                <div style="margin-top: 1.25rem;">
                    <p class="font-mono text-xs uppercase tracking-widest text-gold-500 mb-1">Agent 03</p>
                    <h3 class="serif text-2xl text-ink-900 mb-2">L'Agent Propal</h3>
                    <p class="text-sm text-ink-300 leading-relaxed">
                        Tu cliques, Claude rédige, tu envoies. <em class="not-italic font-medium text-gold-500">2-3h/sem récupérées</em>.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

{# ════════════════════════════════════════════════════════════════
   SECTION 4 — CALENDRIER 14 JOURS (sans P.R.O.M.P.T.-circle [PLACEHOLDER retiré])
   ════════════════════════════════════════════════════════════════ #}
<section class="relative overflow-hidden" style="background: var(--color-cream-200); padding: 8rem 2.5rem;">
    <span class="editorial-number right" aria-hidden="true">02</span>

    <div class="relative z-10" style="max-width: 880px; margin: 0 auto;">
        <div class="reveal" style="margin-bottom: 4rem; text-align: center;">
            <span class="deco-asterisk" aria-hidden="true">*</span>
            <div class="eyebrow-ds" data-centered>Calendrier · 14 jours</div>
            <h2 class="section-title-ds split" data-controller="split-text" style="text-align: center;">
                <em>14 jours</em>, 45 minutes par jour.<br>Trois agents prêts.
            </h2>
            <span class="rule-draw" style="max-width: 200px; margin: 1.5rem auto 0;"></span>
        </div>

        <div class="reveal delay-2">
            <div class="calendar-14" aria-label="Calendrier des 14 jours de formation">
                {% for day in 1..14 %}
                    {% set isFeatured = (day == 1) or (day == 7) or (day == 14) %}
                    {% set isWeekend = ((day % 7) == 6) or ((day % 7) == 0) %}
                    <div class="calendar-day{% if isFeatured %} featured{% elseif isWeekend %} weekend{% endif %}"
                         aria-label="Jour {{ day }}{% if isFeatured %} — étape clé{% endif %}">
                        <span class="calendar-day-num">{{ day }}</span>
                        <span class="calendar-day-label">
                            {% if day == 1 %}Start
                            {% elseif day == 7 %}Mid
                            {% elseif day == 14 %}Goal
                            {% else %}J{{ day }}
                            {% endif %}
                        </span>
                    </div>
                {% endfor %}
            </div>
            <ul class="mt-8 space-y-3 text-sm text-ink-300" style="max-width: 560px; margin-left: auto; margin-right: auto;">
                <li class="flex gap-3">
                    <span class="font-mono text-xs uppercase tracking-widest text-gold-500 min-w-[60px]">J 1-3</span>
                    <span>Setup Claude + Méthode P.R.O.M.P.T.</span>
                </li>
                <li class="flex gap-3">
                    <span class="font-mono text-xs uppercase tracking-widest text-gold-500 min-w-[60px]">J 4-7</span>
                    <span>Construction Agent Inbox + Mission</span>
                </li>
                <li class="flex gap-3">
                    <span class="font-mono text-xs uppercase tracking-widest text-gold-500 min-w-[60px]">J 8-12</span>
                    <span>Agent Propal + Routines anti-erreurs</span>
                </li>
                <li class="flex gap-3">
                    <span class="font-mono text-xs uppercase tracking-widest text-gold-500 min-w-[60px]">J 13-14</span>
                    <span>Bilan + plan post-formation</span>
                </li>
            </ul>
        </div>
    </div>
</section>

{# ════════════════════════════════════════════════════════════════
   SECTION 5 — OFFRES (3 cards : Système Claude, Audit, Consulting)
   ════════════════════════════════════════════════════════════════ #}
<section class="relative overflow-hidden" style="padding: 8rem 2.5rem;">
    <span class="editorial-number left" aria-hidden="true">03</span>

    <div class="relative z-10" style="max-width: 1240px; margin: 0 auto;">
        <div class="reveal">
            <span class="deco-asterisk" aria-hidden="true">*</span>
            <div class="eyebrow-ds">Offres · disponibles</div>
            <h2 class="section-title-ds split" data-controller="split-text">
                Au prix juste,<br><em>tout de suite.</em>
            </h2>
            <span class="rule-draw" style="max-width: 200px; margin-top: 1.5rem;"></span>
        </div>

        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-top: 2.5rem;" class="offers-grid">
            <article class="offer-card-ds reveal delay-1"
                     data-controller="parallax-element card-tilt"
                     data-parallax-element-strength-value="-30">
                <span class="badge-card">Best-seller</span>
                <div class="price-art">147€<small>· 30 places early-bird</small></div>
                <h3>Le <em>Système</em><br>Claude du Consultant</h3>
                <p>Formation 14 jours, 27 vidéos, 3 Agents construits, méthode P.R.O.M.P.T. Garantie 14 jours satisfait ou remboursé.</p>
                <a class="cta" href="/formation-claude-consultant">Découvrir →</a>
            </article>

            <article class="offer-card-ds featured reveal delay-2"
                     data-controller="parallax-element card-tilt"
                     data-parallax-element-strength-value="30">
                <span class="badge-card">Premium</span>
                <div class="price-art">497€<small>· 1h visio + suivi 30j</small></div>
                <h3>L'audit <em>IA</em><br>personnalisé</h3>
                <p>Diagnostic complet de tes process, 3 cas d'usage IA prioritaires, plan d'action 30/60/90 jours. Déduit du consulting si tu enchaînes.</p>
                <a class="cta" href="/audit-ia">Réserver →</a>
            </article>

            <article class="offer-card-ds reveal delay-3"
                     data-controller="parallax-element card-tilt"
                     data-parallax-element-strength-value="-15">
                <div class="price-art">1 500€<small>· à partir de</small></div>
                <h3>Le <em>Consulting</em><br>done-with-you</h3>
                <p>Je construis tes Agents avec toi, je te forme, je te branche sur tes outils. Sur-mesure, devis selon scope.</p>
                <a class="cta" href="/consulting">Discuter →</a>
            </article>
        </div>
    </div>
</section>

{# ════════════════════════════════════════════════════════════════
   SECTION 6 — TÉMOIGNAGE (Sophie M)
   ════════════════════════════════════════════════════════════════ #}
<section class="quote-section">
    <div style="max-width: 1240px; margin: 0 auto;">
        <div class="eyebrow-ds reveal" style="color: var(--color-gold-300);">★ ★ ★ ★ ★ · témoignage vérifié</div>
        <blockquote class="big-q split reveal delay-1" data-controller="split-text">
            « Grâce à Rama, j'ai automatisé 80% de ma création de contenu. Je gagne <em>15h par semaine.</em> Concrètement. »
        </blockquote>
        <span class="rule-draw reveal" style="max-width: 480px; background: var(--color-gold-300); margin-bottom: 1.5rem;"></span>
        <div class="author reveal delay-2">
            <div class="avatar-q">S</div>
            <div>
                <div style="color: var(--color-paper); font-size: var(--text-md); font-weight: 600;">Sophie M.</div>
                <div style="font-family: var(--font-mono); font-size: var(--text-2xs); text-transform: uppercase; letter-spacing: var(--tracking-wider); color: rgba(255,255,255,0.5);">Coach business</div>
            </div>
        </div>
    </div>
</section>

{# ════════════════════════════════════════════════════════════════
   SECTION 7 — FAQ
   ════════════════════════════════════════════════════════════════ #}
{% include 'components/faq.html.twig' with {
    faq: {
        eyebrow: 'Questions fréquentes',
        title: '<em>Questions</em> que tu te poses.',
        items: [
            { question: 'J\'y connais rien en tech, c\'est pour moi ?', answer: 'Absolument. Si tu sais utiliser un navigateur web, tu peux suivre la formation. Je vulgarise tout, j\'explique chaque étape, et on avance ensemble. Pas besoin de coder.' },
            { question: 'Combien de temps prend la formation ?', answer: '14 jours en mode sprint, à raison de 45 min/jour. Tu peux accélérer ou étaler — tu as accès à vie.' },
            { question: 'Quelle version de Claude je dois utiliser ?', answer: 'Claude Sonnet 4.5 (la version pro de Anthropic). On voit ensemble le compte gratuit vs. payant et ce que tu peux faire avec chacun.' },
            { question: 'La garantie 14 jours, c\'est vraiment sans condition ?', answer: 'Oui. Tu m\'écris à hello@instant-ia.com avant J+14, je te rembourse. Pas de questions, pas de petites lignes.' },
            { question: 'Y aura-t-il un Niveau 2 et 3 ?', answer: 'Oui — Niveau 2 (Productivité Pro : Excel, PowerPoint, Skills) et Niveau 3 (Cowork & Automatisation MCP) sont déjà en préparation. Les diplômés Niveau 1 ont un tarif préférentiel.' },
        ],
    }
} only %}

{# ════════════════════════════════════════════════════════════════
   SECTION 8 — LEAD MAGNET (capture email inline) — anchor #lead-magnet
   ════════════════════════════════════════════════════════════════ #}
<section class="cta-final" id="lead-magnet">
    <div class="reveal" style="max-width: 640px; margin: 0 auto;">
        <p class="eyebrow-ds" data-centered style="color: var(--color-ink-700);">
            <span aria-hidden="true">🎁</span>&nbsp;&nbsp;100% gratuit · Sans CB
        </p>

        <h2 class="split" data-controller="split-text" style="margin-top: 1rem;">
            On <em>commence</em><br>par 3 Agents gratuits ?
        </h2>

        <p style="font-size: var(--text-lg); color: rgba(6, 78, 59, 0.78); line-height: var(--leading-relaxed); max-width: 50ch; margin: 0 auto 2.5rem; position: relative; z-index: 1;">
            Trois agents IA Claude prêts à utiliser pour ton contenu, tes emails et ta veille. Tu les configures en 10 minutes.
        </p>

        {# Flash errors — aria-live #}
        <div aria-live="polite" aria-atomic="true" style="position: relative; z-index: 1;">
            {% for label, messages in app.flashes(['error']) %}
                {% for message in messages %}
                    <div role="alert" class="mb-4 mx-auto rounded-lg bg-danger-bg px-4 py-3 text-sm" style="color: var(--color-danger); max-width: 480px;">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}
        </div>

        {# Form inline capture email + checkbox consent #}
        <form method="POST" action="{{ path('lead_magnet_submit') }}"
              class="lead-magnet-form" novalidate>
            <div class="lead-magnet-form-row">
                <label for="home-lead-email" class="sr-only">Ton email</label>
                <input type="email"
                       id="home-lead-email"
                       name="email"
                       required
                       autocomplete="email"
                       placeholder="ton-email@exemple.fr"
                       class="lead-magnet-input">
                <button type="submit" class="cta-final-btn">
                    Recevoir les 3 Agents <span aria-hidden="true">→</span>
                </button>
            </div>
            <label class="lead-magnet-consent">
                <input type="checkbox" name="consent" value="1" required>
                <span>
                    J'accepte de recevoir les 3 agents par email + la newsletter Instant IA.
                    <em style="opacity: 0.6;">Désabonnement en 1 clic, pas de spam.</em>
                </span>
            </label>
        </form>

        <p style="margin-top: 1.5rem; font-family: var(--font-mono); font-size: var(--text-2xs); text-transform: uppercase; letter-spacing: var(--tracking-widest); color: rgba(6, 78, 59, 0.55); position: relative; z-index: 1;">
            Préfères <a href="/3-agents-ia-gratuits" style="color: var(--color-ink-900); text-decoration: underline; text-decoration-color: rgba(6, 78, 59, 0.4); text-underline-offset: 3px;">la version détaillée</a> ?
        </p>
    </div>
</section>

{# ════════════════════════════════════════════════════════════════
