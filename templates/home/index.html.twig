{% extends 'base.html.twig' %}

{% block title %}Instant IA — Plateforme e-learning Claude pour solopreneurs{% endblock %}

{% block body %}
<main data-controller="scroll-reveal">

    {# ─── HERO TEST ─────────────────────────────────────────────────── #}
    <section class="relative overflow-hidden bg-cream-100 px-6 py-20 md:px-12">
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>

        <div class="relative mx-auto max-w-3xl">
            <p class="eyebrow mb-8 rv">Sprint 2.1 · Scroll-driving en place</p>

            <h1 class="serif text-5xl leading-tight text-ink-900 mb-8 md:text-6xl rv d1">
                Le scroll <em>révèle</em>, les chiffres <em>montent</em>, le marquee <em>défile</em>.
            </h1>

            <p class="text-lg leading-relaxed text-ink-300 mb-12 max-w-2xl rv d2">
                Quatre Stimulus controllers portent le pattern legacy vers la stack Symfony UX :
                <span class="font-mono text-sm">scroll-reveal</span>,
                <span class="font-mono text-sm">counter-animation</span>,
                <span class="font-mono text-sm">marquee</span>,
                <span class="font-mono text-sm">faq-accordion</span>.
            </p>

            <a href="#animations" class="inline-flex items-center gap-2 rounded-pill bg-gold-400 px-6 py-3 font-medium text-ink-900 shadow-glow-gold transition hover:bg-gold-500 rv d3">
                <span>Scroll pour voir</span>
                <span aria-hidden="true">↓</span>
            </a>
        </div>
    </section>

    {# ─── MARQUEE ───────────────────────────────────────────────────── #}
    <div class="marquee" data-controller="marquee">
        <div class="marquee-track" data-marquee-target="track">
            <span class="marquee-item">Claude Sonnet 4.5</span>
            <span class="marquee-item">·</span>
            <span class="marquee-item">Projects</span>
            <span class="marquee-item">·</span>
            <span class="marquee-item">Artifacts</span>
            <span class="marquee-item">·</span>
            <span class="marquee-item">Skills</span>
            <span class="marquee-item">·</span>
            <span class="marquee-item">Connecteurs</span>
            <span class="marquee-item">·</span>
            <span class="marquee-item">MCP</span>
            <span class="marquee-item">·</span>
            <span class="marquee-item">Cowork</span>
            <span class="marquee-item">·</span>
            <span class="marquee-item">Sub-agents</span>
            <span class="marquee-item">·</span>
        </div>
    </div>

    {# ─── COMPTEURS ANIMÉS ──────────────────────────────────────────── #}
    <section class="bg-ink-700 px-6 py-20 md:px-12 text-paper" id="animations">
        <div class="mx-auto max-w-5xl">
            <p class="eyebrow mb-8 rv" style="color: var(--color-gold-300);">Compteurs animés</p>
            <h2 class="serif text-4xl leading-tight mb-12 rv d1 md:text-5xl">
                Trois chiffres qui <em>montent</em> au scroll.
            </h2>

            <div class="grid gap-8 sm:grid-cols-3">
                <div class="rv d1">
                    <div class="serif text-6xl text-gold-300 mb-2"
                         data-controller="counter-animation"
                         data-counter-animation-target-value="847"
                         data-counter-animation-suffix-value="+">0</div>
                    <p class="font-mono text-xs uppercase tracking-widest text-paper/60">Heures sauvées</p>
                </div>
                <div class="rv d2">
                    <div class="serif text-6xl text-gold-300 mb-2"
                         data-controller="counter-animation"
                         data-counter-animation-target-value="98"
                         data-counter-animation-suffix-value=" %">0</div>
                    <p class="font-mono text-xs uppercase tracking-widest text-paper/60">Satisfaction</p>
                </div>
                <div class="rv d3">
                    <div class="serif text-6xl text-gold-300 mb-2"
                         data-controller="counter-animation"
                         data-counter-animation-target-value="14">0</div>
                    <p class="font-mono text-xs uppercase tracking-widest text-paper/60">Jours pour avoir tes 3 Agents</p>
                </div>
            </div>
        </div>
    </section>

    {# ─── DÉMO RV-L / RV-R ──────────────────────────────────────────── #}
    <section class="bg-cream-100 px-6 py-20 md:px-12">
        <div class="mx-auto max-w-5xl grid gap-12 md:grid-cols-2">
            <div class="rv-l">
                <p class="eyebrow mb-4">Glissé depuis la gauche</p>
                <h3 class="serif text-3xl leading-tight text-ink-900 mb-4">
                    .rv-l — apparaît <em>en glissant</em>.
                </h3>
                <p class="text-ink-300 leading-relaxed">
                    Idéal pour les blocs éditoriaux qui posent une affirmation à gauche
                    avec sa preuve / illustration à droite.
                </p>
            </div>
            <div class="rv-r d1">
                <p class="eyebrow mb-4">Glissé depuis la droite</p>
                <h3 class="serif text-3xl leading-tight text-ink-900 mb-4">
                    .rv-r — légèrement <em>en retard</em>.
                </h3>
                <p class="text-ink-300 leading-relaxed">
                    Combiné avec un délai (.d1, .d2…), ça crée une chorégraphie d'apparition
                    qui guide l'œil naturellement.
                </p>
            </div>
        </div>
    </section>

    {# ─── FAQ ACCORDION ─────────────────────────────────────────────── #}
    <section class="bg-cream-200 px-6 py-20 md:px-12">
        <div class="mx-auto max-w-3xl">
            <p class="eyebrow mb-4 rv">FAQ accordion</p>
            <h2 class="serif text-4xl leading-tight text-ink-900 mb-12 rv d1 md:text-5xl">
                Questions <em>fréquentes</em>.
            </h2>

            <div class="faq-list rv d2" data-controller="faq-accordion">
                <div class="faq-item" data-faq-accordion-target="item">
                    <button class="faq-question" data-action="click->faq-accordion#toggle">
                        J'y connais rien en tech, c'est pour moi ?
                    </button>
                    <div class="faq-answer">
                        <p>Absolument. Si tu sais utiliser un navigateur web, tu peux suivre mes formations.
                        Je vulgarise tout, j'explique chaque étape, et on avance ensemble. Pas besoin de coder.</p>
                    </div>
                </div>
                <div class="faq-item" data-faq-accordion-target="item">
                    <button class="faq-question" data-action="click->faq-accordion#toggle">
                        C'est en ligne ou en présentiel ?
                    </button>
                    <div class="faq-answer">
                        <p>Principalement en ligne (visio) pour que tu puisses participer où que tu sois.
                        Pour les entreprises, le présentiel est possible sur demande — on en discute.</p>
                    </div>
                </div>
                <div class="faq-item" data-faq-accordion-target="item">
                    <button class="faq-question" data-action="click->faq-accordion#toggle">
                        Comment je récupère mon accès après achat ?
                    </button>
                    <div class="faq-answer">
                        <p>Tu reçois un accès immédiat après paiement. Tu es redirigée vers une page
                        de bienvenue + tu reçois un email de confirmation. Tu peux te reconnecter à tout moment.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {# ─── FOOTER ────────────────────────────────────────────────────── #}
    <footer class="bg-ink-700 px-6 py-12 md:px-12 text-paper">
        <div class="mx-auto max-w-5xl">
            <p class="eyebrow mb-2" style="color: var(--color-gold-300);">Diagnostic technique</p>
            <p class="serif text-xl">
                Sprint 2.1 — Scroll-driving Stimulus
                <em style="color: var(--color-gold-300);">opérationnel</em>.
            </p>
        </div>
    </footer>

</main>
{% endblock %}
