    <div class="reveal">
        <h2 class="split" data-controller="split-text">
            On <em>commence</em><br>maintenant ?
        </h2>
        <p style="font-size: var(--text-lg); color: rgba(6, 78, 59, 0.75); line-height: var(--leading-relaxed); max-width: 50ch; margin: 0 auto 2.5rem; position: relative; z-index: 1;">
