{# ════════════════════════════════════════════════════════════════
   SECTION 5.5 — MÉTHODE P.R.O.M.P.T. + CALENDRIER 14 JOURS
   ════════════════════════════════════════════════════════════════ #}
<section class="relative overflow-hidden" style="background: var(--color-cream-200); padding: 8rem 2.5rem;">
    <span class="editorial-number right" aria-hidden="true">04</span>

    <div class="relative z-10" style="max-width: 1240px; margin: 0 auto;">
        <div class="reveal" style="margin-bottom: 4rem;">
            <span class="deco-asterisk" aria-hidden="true">*</span>
            <div class="eyebrow-ds">Méthode signature</div>
            <h2 class="section-title-ds split" data-controller="split-text">
                <em>P.R.O.M.P.T.</em><br>en 14 jours.
            </h2>
            <span class="rule-draw" style="max-width: 200px; margin-top: 1.5rem;"></span>
        </div>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;" class="prompt-grid">

            {# Diagramme circulaire P.R.O.M.P.T. #}
            <div class="reveal-left">
                <div class="prompt-circle" aria-label="Diagramme P.R.O.M.P.T.">
                    <span class="prompt-letter" style="--prompt-tx: translate(0, -180%); transform: translate(0, -180%);">P</span>
                    <span class="prompt-letter" style="--prompt-tx: translate(160%, -90%); transform: translate(160%, -90%);">R</span>
                    <span class="prompt-letter" style="--prompt-tx: translate(160%, 90%); transform: translate(160%, 90%);">O</span>
                    <span class="prompt-letter" style="--prompt-tx: translate(0, 180%); transform: translate(0, 180%);">M</span>
                    <span class="prompt-letter" style="--prompt-tx: translate(-160%, 90%); transform: translate(-160%, 90%);">P</span>
                    <span class="prompt-letter" style="--prompt-tx: translate(-160%, -90%); transform: translate(-160%, -90%);">T</span>
                </div>
                <p class="text-center font-mono text-2xs uppercase tracking-widest text-ink-300 mt-6">
                    [PLACEHOLDER : 6 lettres + significations à fournir par Rama]
                </p>
            </div>

            {# Calendrier 14 jours #}
            <div class="reveal-right delay-2">
                <p class="eyebrow-ds mb-4">Sprint 14 jours · 45 min/jour</p>
                <div class="calendar-14" aria-label="Calendrier des 14 jours de formation">
                    {% for day in 1..14 %}
                        {% set isFeatured = (day == 1) or (day == 7) or (day == 14) %}
                        {% set isWeekend = ((day % 7) == 6) or ((day % 7) == 0) %}
                        <div class="calendar-day{% if isFeatured %} featured{% elseif isWeekend %} weekend{% endif %}"
                             aria-label="Jour {{ day }}{% if isFeatured %} — étape clé{% endif %}">
                            <span class="calendar-day-num">{{ day }}</span>
                            <span class="calendar-day-label">
                                {% if day == 1 %}Start
                                {% elseif day == 7 %}Mid
                                {% elseif day == 14 %}Goal
                                {% else %}J{{ day }}
                                {% endif %}
                            </span>
                        </div>
                    {% endfor %}
                </div>
                <ul class="mt-6 space-y-2 text-sm text-ink-300">
                    <li class="flex gap-3">
                        <span class="font-mono text-xs uppercase tracking-widest text-gold-500 min-w-[60px]">J 1-3</span>
                        <span>Setup Claude + Méthode P.R.O.M.P.T.</span>
                    </li>
                    <li class="flex gap-3">
                        <span class="font-mono text-xs uppercase tracking-widest text-gold-500 min-w-[60px]">J 4-7</span>
                        <span>Construction Agent Inbox + Mission</span>
                    </li>
                    <li class="flex gap-3">
                        <span class="font-mono text-xs uppercase tracking-widest text-gold-500 min-w-[60px]">J 8-12</span>
                        <span>Agent Propal + Routines anti-erreurs</span>
                    </li>
                    <li class="flex gap-3">
                        <span class="font-mono text-xs uppercase tracking-widest text-gold-500 min-w-[60px]">J 13-14</span>
                        <span>Bilan + plan post-formation</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</section>

