<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Instant IA — Plateforme e-learning{% endblock %}{% block titleSuffix %} | Instant IA{% endblock %}</title>
    <meta name="description" content="{% block description %}Instant IA aide les solopreneurs à exploiter Claude pour automatiser leur business.{% endblock %}">

    <link rel="icon" type="image/svg+xml" href="/favicon-instant-ia.svg">
    <link rel="alternate icon" href="/favicon-instant-ia.svg">
    <link rel="apple-touch-icon" href="/favicon-instant-ia.svg">

    {# Préchargement des polices critiques (Inter regular + Instrument Serif italic = signature DS) #}
    <link rel="preload" as="font" type="font/woff2" href="{{ asset('fonts/inter-v20-latin-regular.woff2') }}" crossorigin>
    <link rel="preload" as="font" type="font/woff2" href="{{ asset('fonts/instrument-serif-v5-latin-italic.woff2') }}" crossorigin>

    {% block stylesheets %}
        <link rel="stylesheet" href="{{ asset('styles/app.css') }}">
    {% endblock %}

    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body data-controller="scroll-reveal cursor-follower">

    {# Skip-link pour utilisateurs clavier — visible au focus uniquement #}
    <a href="#main-content" class="skip-link">Aller au contenu</a>

    {% block header %}
        {% include 'components/header.html.twig' %}
    {% endblock %}

    <main id="main-content" tabindex="-1">
        {% block body %}{% endblock %}
    </main>

    {% block footer %}
        {% include 'components/footer.html.twig' %}
    {% endblock %}

</body>
</html>
