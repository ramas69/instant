<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Bienvenue dans Le Système Claude</title>
</head>
<body style="margin: 0; padding: 0; background-color: #FAF8F4; font-family: 'Helvetica Neue', Arial, sans-serif; color: #1B2B25;">

    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #FAF8F4;">
        <tr>
            <td align="center" style="padding: 40px 20px;">
                <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" style="max-width: 600px; background-color: #FFFFFF; border-radius: 16px; overflow: hidden; box-shadow: 0 4px 12px rgba(6, 78, 59, 0.06);">

                    {# Header #}
                    <tr>
                        <td style="background-color: #064E3B; padding: 32px 40px; text-align: center;">
                            <p style="margin: 0; color: #E8C547; font-family: 'Georgia', serif; font-size: 28px; line-height: 1;">
                                Instant <em style="color: #FFFFFF;">IA</em>
                            </p>
                        </td>
                    </tr>

                    {# Hero #}
                    <tr>
                        <td style="padding: 48px 40px 32px;">
                            <p style="margin: 0 0 8px; color: #C5A044; font-family: monospace; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;">
                                Confirmation
                            </p>
                            <h1 style="margin: 0 0 16px; font-family: 'Georgia', serif; font-size: 32px; line-height: 1.2; color: #051F18; font-weight: normal;">
                                Bienvenue dans <em style="color: #C5A044;">Le Système Claude</em>.
                            </h1>
                            <p style="margin: 0; font-size: 16px; line-height: 1.6; color: #3D564B;">
                                Bonjour {{ achat.acheteur.email|split('@')|first }},<br><br>
                                Ton paiement de <strong style="color: #051F18;">{{ (achat.montantCentimes / 100)|number_format(0, ',', ' ') }} €</strong>
                                pour <em>{{ achat.cours.titre }}</em> a été reçu et confirmé. Bienvenue à bord !
                            </p>
                        </td>
                    </tr>

                    {# Étapes #}
                    <tr>
                        <td style="padding: 0 40px 32px;">
                            <h2 style="margin: 0 0 16px; font-family: 'Georgia', serif; font-size: 20px; color: #051F18; font-weight: normal;">
                                Tes prochaines étapes
                            </h2>

                            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin-bottom: 16px;">
                                <tr>
                                    <td width="40" valign="top">
                                        <div style="width: 32px; height: 32px; background-color: #D4AF37; color: #051F18; border-radius: 50%; text-align: center; line-height: 32px; font-weight: bold;">1</div>
                                    </td>
                                    <td valign="top" style="padding-left: 12px; padding-bottom: 16px; font-size: 15px; line-height: 1.5; color: #3D564B;">
                                        <strong style="color: #051F18;">Le Module 0</strong> arrive demain matin dans cette boîte mail. Bloque 45 min/jour pendant 14 jours.
                                    </td>
                                </tr>
                                <tr>
                                    <td width="40" valign="top">
                                        <div style="width: 32px; height: 32px; background-color: #D4AF37; color: #051F18; border-radius: 50%; text-align: center; line-height: 32px; font-weight: bold;">2</div>
                                    </td>
                                    <td valign="top" style="padding-left: 12px; padding-bottom: 16px; font-size: 15px; line-height: 1.5; color: #3D564B;">
                                        <strong style="color: #051F18;">Communauté privée</strong> : le lien WhatsApp arrive dans l'email du Module 0.
                                    </td>
                                </tr>
                                <tr>
                                    <td width="40" valign="top">
                                        <div style="width: 32px; height: 32px; background-color: #D4AF37; color: #051F18; border-radius: 50%; text-align: center; line-height: 32px; font-weight: bold;">3</div>
                                    </td>
                                    <td valign="top" style="padding-left: 12px; font-size: 15px; line-height: 1.5; color: #3D564B;">
                                        <strong style="color: #051F18;">Garantie 14 jours</strong> : si tu n'as pas tes 3 Agents opérationnels, je te rembourse. Sans question.
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    {# CTA #}
                    <tr>
                        <td style="padding: 0 40px 40px;" align="center">
                            <a href="https://instant-ia.com/" style="display: inline-block; background-color: #D4AF37; color: #051F18; padding: 14px 28px; border-radius: 999px; text-decoration: none; font-weight: 500; font-size: 16px;">
                                Retour sur instant-ia.com →
                            </a>
                        </td>
                    </tr>

                    {# Récap #}
                    <tr>
                        <td style="background-color: #F0EBE1; padding: 24px 40px; font-size: 13px; color: #6B877B;">
                            <p style="margin: 0 0 4px;"><strong style="color: #3D564B;">Récap commande</strong></p>
                            <p style="margin: 0;">
                                Référence : {{ achat.id|slice(0, 8) }} ·
                                Stripe Session : {{ achat.stripeSessionId }} ·
                                Date : {{ achat.paidAt ? achat.paidAt|date('d/m/Y à H:i') : achat.createdAt|date('d/m/Y à H:i') }}
                            </p>
                        </td>
                    </tr>

                    {# Footer #}
                    <tr>
                        <td style="padding: 24px 40px; text-align: center; font-size: 12px; color: #6B877B;">
                            <p style="margin: 0 0 8px;">
                                Une question ? Réponds à cet email ou écris à
                                <a href="mailto:hello@instant-ia.com" style="color: #C5A044;">hello@instant-ia.com</a>
                            </p>
                            <p style="margin: 0; font-family: monospace; font-size: 11px; letter-spacing: 0.1em;">
                                Instant IA · Rama Soumaré
                            </p>
                        </td>
                    </tr>

                </table>
            </td>
        </tr>
    </table>

</body>
</html>
