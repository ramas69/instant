{% extends 'base.html.twig' %}
{% import 'components/_buttons.html.twig' as buttons %}

{% block title %}Récupère 3 Agents IA Claude gratuits{% endblock %}
{% block titleSuffix %} | Instant IA{% endblock %}
{% block description %}Télécharge gratuitement 3 agents IA Claude prêts à l'emploi pour automatiser ton contenu, tes emails et ta veille. En 10 minutes, sans CB.{% endblock %}

{% block body %}

{# ════════════════════════════════════════════════════════════════
   SECTION 1 — HERO + FORMULAIRE
   ════════════════════════════════════════════════════════════════ #}
<section class="relative overflow-hidden bg-cream-100 px-6 py-24 md:px-12 md:py-32">
    <div class="blob blob-1" aria-hidden="true"></div>
    <div class="blob blob-2" aria-hidden="true"></div>

    <div class="relative mx-auto max-w-6xl">
        <div class="grid items-start gap-12 lg:grid-cols-2">

            <div>
                <div class="mb-6 inline-flex items-center gap-2 rounded-pill bg-gold-100 px-4 py-1.5 font-mono text-2xs uppercase tracking-widest text-ink-700 rv">
                    <span aria-hidden="true">⚡</span>
                    <span>100% gratuit · Accès immédiat</span>
                </div>

                <h1 class="serif text-4xl leading-tight text-ink-900 rv d1 sm:text-5xl md:text-6xl">
                    3 Agents IA <em>du Solopreneur.</em>
                </h1>

                <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-300 rv d2 md:text-xl">
                    Automatise ton contenu, tes emails et ta veille avec 3 agents Claude prêts à l'emploi.
                    Configure-les en 10 minutes, sans compétence technique.
                </p>

                <ul class="mt-8 space-y-3 rv d3">
                    <li class="flex items-center gap-3 text-ink-900">
                        <span class="text-gold-500" aria-hidden="true">✓</span>
                        <span>3 templates avec instructions complètes</span>
                    </li>
                    <li class="flex items-center gap-3 text-ink-900">
                        <span class="text-gold-500" aria-hidden="true">✓</span>
                        <span>Compatible Claude (gratuit ou Pro)</span>
                    </li>
                    <li class="flex items-center gap-3 text-ink-900">
                        <span class="text-gold-500" aria-hidden="true">✓</span>
                        <span>0 € — aucune CB requise</span>
                    </li>
                </ul>
            </div>

            {# Form card #}
            <div class="rv-r d2">
                <div class="rounded-2xl bg-paper p-8 shadow-4">
                    <div class="mb-5 inline-flex h-12 w-12 items-center justify-center rounded-full bg-gold-400 text-2xl shadow-glow-gold">
                        <span aria-hidden="true">⚡</span>
                    </div>
                    <h2 class="serif mb-2 text-2xl text-ink-900">
                        Accès immédiat & gratuit
                    </h2>
                    <p class="mb-6 text-sm leading-relaxed text-ink-300">
                        Reçois les 3 agents par email en 30 secondes.
                    </p>

                    {# Flash errors — aria-live pour annonce screen readers #}
                    <div aria-live="polite" aria-atomic="true">
                        {% for label, messages in app.flashes(['error']) %}
                            {% for message in messages %}
                                <div role="alert" class="mb-4 rounded-lg bg-danger-bg px-4 py-3 text-sm" style="color: var(--color-danger);">
                                    {{ message }}
                                </div>
                            {% endfor %}
                        {% endfor %}
                    </div>

                    <form method="POST" action="{{ path('lead_magnet_submit') }}" class="space-y-4" novalidate>
                        <div>
                            <label for="lead-email" class="sr-only">Ton email</label>
                            <input type="email"
                                   id="lead-email"
                                   name="email"
                                   required
                                   autocomplete="email"
                                   placeholder="ton-email@exemple.fr"
                                   class="w-full rounded-pill border border-ink-700/15 bg-paper px-5 py-3 text-ink-900 placeholder:text-ink-200 focus:border-gold-400 focus:outline-none focus:ring-2 focus:ring-gold-300/40">
                        </div>

                        <label class="flex items-start gap-3 text-sm leading-relaxed text-ink-300">
                            <input type="checkbox" name="consent" value="1" required class="mt-1 h-4 w-4 rounded border-ink-300 text-gold-500 focus:ring-gold-400">
                            <span>
                                J'accepte de recevoir les 3 agents par email + la newsletter hebdo Instant IA.
                                <em class="not-italic text-ink-200">Désabonnement en 1 clic.</em>
                            </span>
                        </label>

                        <button type="submit"
                                class="inline-flex w-full items-center justify-center gap-2 rounded-pill bg-gold-400 px-6 py-3.5 font-medium text-ink-900 shadow-glow-gold transition hover:bg-gold-500">
                            <span>Recevoir les 3 Agents</span>
                            <span aria-hidden="true">→</span>
                        </button>

                        <p class="text-center font-mono text-2xs uppercase tracking-widest text-ink-200">
                            Désabonnement en 1 clic · pas de spam
                        </p>
                    </form>
                </div>
            </div>

        </div>
    </div>
</section>

{# ════════════════════════════════════════════════════════════════
   SECTION 2 — CE QUE TU REÇOIS (3 AGENTS)
   ════════════════════════════════════════════════════════════════ #}
<section class="bg-cream-50 px-6 py-24 md:px-12">
    <div class="mx-auto max-w-5xl">
        <p class="eyebrow mb-4 rv">Ce que tu reçois</p>
        <h2 class="serif mb-12 max-w-3xl text-4xl leading-tight text-ink-900 rv d1 md:text-5xl">
            3 agents IA, prêts à <em>bosser pour toi</em>.
        </h2>

        <div class="grid gap-6 md:grid-cols-3">
            <article class="rounded-2xl bg-paper p-7 shadow-2 rv">
                <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-gold-100 text-2xl">
                    <span aria-hidden="true">📝</span>
                </div>
                <p class="mb-2 font-mono text-xs uppercase tracking-widest text-gold-500">Agent 01</p>
                <h3 class="serif mb-3 text-xl leading-snug text-ink-900">L'Agent Contenu</h3>
                <ul class="mb-5 space-y-2 text-sm text-ink-300">
                    <li class="flex gap-2"><span class="text-gold-500" aria-hidden="true">·</span><span>Génère des idées de posts LinkedIn</span></li>
                    <li class="flex gap-2"><span class="text-gold-500" aria-hidden="true">·</span><span>Rédige des brouillons structurés</span></li>
                    <li class="flex gap-2"><span class="text-gold-500" aria-hidden="true">·</span><span>Adapte le ton à ta marque</span></li>
                </ul>
                <div class="rounded-lg bg-gold-100 px-4 py-3 font-mono text-xs text-ink-700">
                    → 5 posts/semaine en 20 min au lieu de 3h
                </div>
            </article>

            <article class="rounded-2xl bg-paper p-7 shadow-2 rv d1">
                <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-gold-100 text-2xl">
                    <span aria-hidden="true">💌</span>
                </div>
                <p class="mb-2 font-mono text-xs uppercase tracking-widest text-gold-500">Agent 02</p>
                <h3 class="serif mb-3 text-xl leading-snug text-ink-900">L'Agent Email</h3>
                <ul class="mb-5 space-y-2 text-sm text-ink-300">
                    <li class="flex gap-2"><span class="text-gold-500" aria-hidden="true">·</span><span>Écrit des séquences email engageantes</span></li>
                    <li class="flex gap-2"><span class="text-gold-500" aria-hidden="true">·</span><span>Personnalise les relances clients</span></li>
                    <li class="flex gap-2"><span class="text-gold-500" aria-hidden="true">·</span><span>Optimise les objets pour l'ouverture</span></li>
                </ul>
                <div class="rounded-lg bg-gold-100 px-4 py-3 font-mono text-xs text-ink-700">
                    → +40 % de taux d'ouverture en moyenne
                </div>
            </article>

            <article class="rounded-2xl bg-paper p-7 shadow-2 rv d2">
                <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-2xl bg-gold-100 text-2xl">
                    <span aria-hidden="true">📊</span>
                </div>
                <p class="mb-2 font-mono text-xs uppercase tracking-widest text-gold-500">Agent 03</p>
                <h3 class="serif mb-3 text-xl leading-snug text-ink-900">L'Agent Veille</h3>
                <ul class="mb-5 space-y-2 text-sm text-ink-300">
                    <li class="flex gap-2"><span class="text-gold-500" aria-hidden="true">·</span><span>Surveille ton secteur automatiquement</span></li>
                    <li class="flex gap-2"><span class="text-gold-500" aria-hidden="true">·</span><span>Résume les tendances clés</span></li>
                    <li class="flex gap-2"><span class="text-gold-500" aria-hidden="true">·</span><span>Te prépare un brief quotidien</span></li>
                </ul>
                <div class="rounded-lg bg-gold-100 px-4 py-3 font-mono text-xs text-ink-700">
                    → 1h de veille compressée en 5 min
                </div>
            </article>
        </div>
    </div>
</section>

{# ════════════════════════════════════════════════════════════════
   SECTION 3 — QUI EST RAMA (court)
   ════════════════════════════════════════════════════════════════ #}
<section class="bg-cream-100 px-6 py-20 md:px-12">
    <div class="mx-auto max-w-3xl">
        <div class="flex items-center gap-6 rv">
            <div class="flex h-20 w-20 flex-shrink-0 items-center justify-center rounded-full bg-ink-700">
                <span class="serif text-3xl text-gold-300">R</span>
            </div>
            <div>
                <p class="eyebrow mb-1">Qui je suis</p>
                <p class="text-lg leading-relaxed text-ink-300">
                    <em class="not-italic font-medium text-ink-900">Rama Soumaré</em> — formatrice IA & cofondatrice technique.
                    J'aide les solopreneurs à dompter Claude pour automatiser leur business. Zéro blabla, que de l'actionnable.
                </p>
            </div>
        </div>
    </div>
</section>

{# ════════════════════════════════════════════════════════════════
   SECTION 4 — GARANTIE NO-SPAM
   ════════════════════════════════════════════════════════════════ #}
<section class="bg-gold-100 px-6 py-16 md:px-12">
    <div class="mx-auto max-w-2xl text-center">
        <p class="serif text-2xl leading-snug text-ink-900 rv">
            <em>Désabonnement en 1 clic</em>, pas de spam, pas de revente d'email.
        </p>
        <p class="mt-3 font-mono text-xs uppercase tracking-widest text-ink-700 rv d1">
            1 email/semaine maximum · respect RGPD strict
        </p>
    </div>
</section>

{% endblock %}
