{% extends 'base.html.twig' %}
{% import 'components/_buttons.html.twig' as buttons %}

{% block title %}Le Système Claude du Consultant — Formation IA en 14 jours{% endblock %}
{% block titleSuffix %} | Instant IA{% endblock %}
{% block description %}Formation Claude IA pour consultants et formateurs solo. 27 vidéos, 3 agents IA construits, méthode P.R.O.M.P.T. 147€ (offre fondateur). Garantie 14j.{% endblock %}

{% block body %}

{# ════════════════════════════════════════════════════════════════
   SECTION 1 — HERO PAGE DE VENTE
   ════════════════════════════════════════════════════════════════ #}
<section class="relative overflow-hidden bg-cream-100 px-6 py-24 md:px-12 md:py-32">
    <div class="blob blob-1" aria-hidden="true"></div>
    <div class="blob blob-2" aria-hidden="true"></div>

    <div class="relative mx-auto max-w-6xl">
        <div class="grid items-center gap-12 lg:grid-cols-[1.2fr_1fr]">

            <div>
                <p class="eyebrow mb-6 rv">Formation · 14 jours · Pour solos</p>
                <h1 class="serif text-4xl leading-tight text-ink-900 rv d1 sm:text-5xl md:text-6xl">
                    Le <em>Système Claude</em> du Consultant.
                </h1>
                <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-300 rv d2 md:text-xl">
                    En 14 jours, tu construis tes 3 Agents IA, tu maîtrises la méthode P.R.O.M.P.T.
                    et tu récupères 9 à 12 heures par semaine. Sans coder. Sans devenir tech.
                </p>

                <ul class="mt-8 space-y-3 rv d3">
                    <li class="flex items-start gap-3 text-ink-900">
                        <span class="mt-1 text-gold-500" aria-hidden="true">✓</span>
                        <span><em class="not-italic font-medium">27 vidéos courtes</em> (3-5 min) — 45 min/jour seulement</span>
                    </li>
                    <li class="flex items-start gap-3 text-ink-900">
                        <span class="mt-1 text-gold-500" aria-hidden="true">✓</span>
                        <span><em class="not-italic font-medium">3 Agents Claude opérationnels</em> à la fin du sprint</span>
                    </li>
                    <li class="flex items-start gap-3 text-ink-900">
                        <span class="mt-1 text-gold-500" aria-hidden="true">✓</span>
                        <span><em class="not-italic font-medium">Garantie 14 jours</em> sans questions, sans petites lignes</span>
                    </li>
                </ul>

                <div class="mt-10 flex flex-wrap items-center gap-4 rv d4">
                    {{ buttons.primary('Je rejoins (147€)', '/achat/le-systeme-claude-du-consultant') }}
                    {{ buttons.ghost('Voir le programme', '#programme', { arrow: true }) }}
                </div>

                {# Compteur scarcity #}
                <div class="mt-8 inline-flex items-center gap-3 rounded-pill bg-gold-100 px-4 py-2 rv d5">
                    <span class="relative flex h-3 w-3">
                        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-gold-400 opacity-75"></span>
                        <span class="relative inline-flex h-3 w-3 rounded-full bg-gold-400"></span>
                    </span>
                    <span class="font-mono text-xs uppercase tracking-widest text-ink-700">
                        <span data-controller="counter-animation"
                              data-counter-animation-target-value="27">0</span>
                        places fondateur restantes sur 30
                    </span>
                </div>
            </div>

            {# Bloc droite — VSL placeholder ou hero card #}
            <div class="rv-r d2">
                <div class="rounded-2xl bg-paper p-2 shadow-4">
                    <div class="aspect-video flex items-center justify-center rounded-xl bg-ink-700 text-paper">
                        <div class="text-center">
                            <div class="serif text-6xl text-gold-300">▶</div>
                            <p class="mt-4 font-mono text-xs uppercase tracking-widest text-paper/60">
                                [PLACEHOLDER : VSL Vimeo]
                            </p>
                        </div>
                    </div>
                </div>
                <p class="mt-3 text-center font-mono text-2xs uppercase tracking-widest text-ink-200">
                    [PLACEHOLDER : ID Vimeo de la vidéo de vente à fournir]
                </p>
            </div>

        </div>
    </div>
</section>

{# ════════════════════════════════════════════════════════════════
   SECTION 2 — STORYTELLING SANDRA
   ════════════════════════════════════════════════════════════════ #}
<section class="bg-cream-50 px-6 py-24 md:px-12">
    <div class="mx-auto max-w-3xl">
        <p class="eyebrow mb-4 rv">L'histoire de Sandra</p>
        <h2 class="serif mb-12 text-4xl leading-tight text-ink-900 rv d1 md:text-5xl">
            L'histoire de Sandra <em>(et probablement la tienne aussi)</em>.
        </h2>

        <div class="space-y-5 text-lg leading-relaxed text-ink-300 rv d2">
            <p>
                Sandra a 39 ans. Elle est consultante en transformation managériale à Lyon.
                Ex-cadre RH dans un grand groupe. En solo depuis 2 ans et demi.
            </p>
            <p>
                Sur le papier, ça tourne : 80K€ de CA, 8 clients en parallèle, des recommandations
                qui arrivent. Mais elle bosse 55 heures par semaine. Elle rédige ses propals à 23h.
                Elle se sent submergée.
            </p>

            <div class="rounded-2xl border border-dashed border-ink-300/30 bg-paper p-6 my-8 text-center">
                <p class="font-mono text-2xs uppercase tracking-widest text-ink-200 mb-3">
                    [PLACEHOLDER : storytelling Sandra 300-400 mots]
                </p>
                <p class="text-sm text-ink-300">
                    À fournir par Rama : développement de l'arc narratif Sandra
                    (découverte ChatGPT déçue → premier contact Claude → installation des 3 Agents
                    → transformation business). Ton : émotionnel, identification forte, voix Instant IA
                    (tutoiement direct, zéro blabla).
                </p>
            </div>

            <p class="serif text-2xl italic leading-snug text-gold-500">
                « Si tu te reconnais ne serait-ce qu'à moitié dans Sandra,
                cette formation a été pensée pour toi. »
            </p>
        </div>
    </div>
</section>

{# ════════════════════════════════════════════════════════════════
   SECTION 3 — LES 7 MODULES
   ════════════════════════════════════════════════════════════════ #}
<section id="programme" class="bg-cream-100 px-6 py-24 md:px-12">
    <div class="mx-auto max-w-5xl">
        <p class="eyebrow mb-4 rv">Programme détaillé</p>
        <h2 class="serif mb-3 max-w-3xl text-4xl leading-tight text-ink-900 rv d1 md:text-5xl">
            Ce que tu apprends en <em>14 jours</em>.
        </h2>
        <p class="mb-12 max-w-2xl text-lg text-ink-300 rv d2">
            7 modules, 27 vidéos courtes (3-5 min). Tout est conçu pour 45 minutes par jour, sprint sur 14 jours.
            Tu peux ralentir, accélérer, revenir : tu as accès à vie.
        </p>

        {% include 'components/module-accordion.html.twig' with {
            modules: [
                { code: 'M0', title: 'Bienvenue & Quick Win', description: 'Pose les bases avant tout. En 30 minutes, tu obtiens ton premier résultat concret avec Claude — ce qui te donne la confiance pour la suite.', videoCount: 3 },
                { code: 'M1', title: 'Comprendre Claude', description: 'Comment Claude pense, ce qu\'il sait faire (vraiment), et comment lui parler pour qu\'il donne le meilleur. La différence avec ChatGPT, les pièges, les forces.', videoCount: 4 },
                { code: 'M2', title: 'Méthode P.R.O.M.P.T.', description: 'La méthode signature. Une fois mémorisée, tu n\'écris plus jamais un mauvais prompt. Structure universelle qui marche pour toutes tes tâches consultant.', videoCount: 5, featured: true },
                { code: 'M3', title: 'Projects Claude', description: 'Comment structurer ton travail dans des Projects Claude pour qu\'il garde le contexte d\'une mission à l\'autre. Fini de tout ré-expliquer à chaque fois.', videoCount: 4 },
                { code: 'M4', title: 'Construire tes 3 Agents', description: 'On passe à l\'action. Tu construis Agent Inbox, Agent Mission et Agent Propal pas à pas, ensemble, avec ton vrai contenu. À la fin du module, tes 3 Agents tournent.', videoCount: 6, featured: true },
                { code: 'M5', title: 'Routines & anti-erreurs', description: 'Comment intégrer Claude dans ta journée et éviter les pièges classiques (hallucinations, dérives, oublis de contexte, sécurité des données client).', videoCount: 3 },
                { code: 'M6', title: 'Et après ?', description: 'La suite : comment progresser, le Niveau 2, Le Cercle, les ressources continues. Comment rester à jour sur Claude (qui évolue vite).', videoCount: 2 },
            ]
        } only %}
    </div>
</section>

{# ════════════════════════════════════════════════════════════════
   SECTION 4 — LES 3 AGENTS DÉTAILLÉS
   ════════════════════════════════════════════════════════════════ #}
<section class="bg-cream-200 px-6 py-24 md:px-12">
    <div class="mx-auto max-w-5xl">
        <p class="eyebrow mb-4 rv">Tes 3 Agents Claude</p>
        <h2 class="serif mb-12 max-w-3xl text-4xl leading-tight text-ink-900 rv d1 md:text-5xl">
            Les 3 Agents que tu vas <em>construire ensemble</em>.
        </h2>

        <div class="space-y-12">

            {# Agent Inbox #}
            <article class="grid items-start gap-8 md:grid-cols-[auto_1fr] rv">
                <div class="flex h-20 w-20 items-center justify-center rounded-2xl bg-gold-400 text-4xl shadow-glow-gold">
                    📧
                </div>
                <div>
                    <p class="mb-2 font-mono text-xs uppercase tracking-widest text-gold-500">Agent 01</p>
                    <h3 class="serif mb-3 text-3xl leading-tight text-ink-900">L'Agent Inbox</h3>
                    <p class="mb-4 text-lg leading-relaxed text-ink-300">
                        Trie tes emails entrants par priorité, pré-rédige les réponses dans ton ton à toi,
                        gère tes relances clients en silence. Tu ouvres Gmail, 80% du boulot est déjà fait.
                    </p>
                    <div class="rounded-lg bg-paper px-5 py-3 font-mono text-sm text-ink-700">
                        → <em class="not-italic font-medium text-gold-500">4 à 5 heures par semaine</em> récupérées
                    </div>
                </div>
            </article>

            {# Agent Mission #}
            <article class="grid items-start gap-8 md:grid-cols-[auto_1fr] rv d1">
                <div class="flex h-20 w-20 items-center justify-center rounded-2xl bg-gold-400 text-4xl shadow-glow-gold">
                    🎙️
                </div>
                <div>
                    <p class="mb-2 font-mono text-xs uppercase tracking-widest text-gold-500">Agent 02</p>
                    <h3 class="serif mb-3 text-3xl leading-tight text-ink-900">L'Agent Mission</h3>
                    <p class="mb-4 text-lg leading-relaxed text-ink-300">
                        Synthétise tes calls clients en compte-rendus pro structurés. Tu termines un call,
                        tu copies la transcription, Claude te sort un CR prêt à envoyer avec plan d'action.
                    </p>
                    <div class="rounded-lg bg-paper px-5 py-3 font-mono text-sm text-ink-700">
                        → <em class="not-italic font-medium text-gold-500">3 à 4 heures par semaine</em> récupérées
                    </div>
                </div>
            </article>

            {# Agent Propal #}
            <article class="grid items-start gap-8 md:grid-cols-[auto_1fr] rv d2">
                <div class="flex h-20 w-20 items-center justify-center rounded-2xl bg-gold-400 text-4xl shadow-glow-gold">
                    📋
                </div>
                <div>
                    <p class="mb-2 font-mono text-xs uppercase tracking-widest text-gold-500">Agent 03</p>
                    <h3 class="serif mb-3 text-3xl leading-tight text-ink-900">L'Agent Propal</h3>
                    <p class="mb-4 text-lg leading-relaxed text-ink-300">
                        Génère tes propositions commerciales en 15 minutes. Tu remplis 3 champs (client, contexte, scope),
                        Claude te sort une propal calibrée à ton offre, à ton pricing, à ton ton.
                    </p>
                    <div class="rounded-lg bg-paper px-5 py-3 font-mono text-sm text-ink-700">
                        → <em class="not-italic font-medium text-gold-500">2 à 3 heures par semaine</em> récupérées
                    </div>
                </div>
            </article>

        </div>
    </div>
</section>

{# ════════════════════════════════════════════════════════════════
   SECTION 5 — MÉTHODE P.R.O.M.P.T.
   ════════════════════════════════════════════════════════════════ #}
<section class="bg-ink-700 px-6 py-24 md:px-12 text-paper">
    <div class="mx-auto max-w-5xl text-center">
        <p class="eyebrow mb-4 rv" style="color: var(--color-gold-300);">Méthode signature</p>
        <h2 class="serif mb-6 text-4xl leading-tight rv d1 md:text-5xl">
            La méthode <em>P.R.O.M.P.T.</em>
        </h2>
        <p class="mx-auto mb-12 max-w-2xl text-lg text-paper/80 rv d2">
            Une structure universelle de 6 étapes. Une fois mémorisée, tu n'écris plus jamais un mauvais prompt.
            Tes consultants la mémorisent en 30 minutes, l'appliquent à vie.
        </p>

        <div class="flex flex-wrap justify-center gap-3 rv d3">
            {% for letter in ['P', 'R', 'O', 'M', 'P', 'T'] %}
                <div class="flex h-24 w-24 items-center justify-center rounded-2xl bg-gold-400 font-mono text-4xl font-bold text-ink-900 shadow-glow-gold">
                    {{ letter }}
                </div>
            {% endfor %}
        </div>

        <div class="mt-12 rounded-2xl border border-dashed border-paper/20 bg-ink-900 p-6 max-w-2xl mx-auto rv d4">
            <p class="font-mono text-2xs uppercase tracking-widest text-gold-300 mb-3">
                [PLACEHOLDER : signification des 6 lettres]
            </p>
            <p class="text-sm text-paper/70">
                Rama, dans le brief v2 tu as nommé l'acronyme P.R.O.M.P.T. mais sans préciser la signification
                de chaque lettre. À fournir avant lancement : la décomposition complète des 6 étapes.
            </p>
        </div>
    </div>
</section>

{# ════════════════════════════════════════════════════════════════
