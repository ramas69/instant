{% extends 'base.html.twig' %}
{% import 'components/_buttons.html.twig' as buttons %}

{# ════════════════════════════════════════════════════════════════
   PAGE NIVEAU 01 — LE SYSTÈME CLAUDE DU CONSULTANT
   Refonte Apple economy : 9 sections, une question par section.
   Réponse à la cible Sandra : soulagement avant aspiration.
   ════════════════════════════════════════════════════════════════ #}

{% block title %}Le Système Claude du Consultant — Formation IA en 14 jours{% endblock %}
{% block titleSuffix %} | Instant IA{% endblock %}
{% block description %}Formation Claude IA pour consultants et formateurs solo. 27 vidéos, 3 agents IA construits, méthode P.R.O.M.P.T. 147€ offre fondateur. Garantie 14 jours.{% endblock %}

{% set checkout_url = '/achat/le-systeme-claude-du-consultant' %}

{% block body %}

{# ════════════════════════════════════════════════════════════════
   SECTION 01 — HERO (100vh)
   Soulagement immédiat. Une promesse. Un CTA. Pas de scroll arrow.
   ════════════════════════════════════════════════════════════════ #}
<section class="bg-cream-100 px-6 md:px-20"
         style="min-height: 100vh; display: flex; align-items: center;"
         aria-labelledby="hero-title">
    <div class="mx-auto w-full" style="max-width: 1200px;">

        <p class="eyebrow-ds rv text-gold-500">
            Le système · Niveau 01
        </p>

        <h1 id="hero-title"
            class="serif text-ink-900 mt-8 rv d1"
            style="font-size: clamp(3.5rem, 9vw, 6.875rem); line-height: 0.95; font-weight: 400; letter-spacing: -0.02em;">
            Claude,<br>
            ton bras droit.<br>
            <em>En 14 jours.</em>
        </h1>

        <p class="mt-12 text-ink-300 rv d2"
           style="max-width: 540px; font-size: clamp(1.0625rem, 1.5vw, 1.25rem); line-height: 1.6;">
            Pour les consultantes solo qui veulent récupérer dix heures par semaine.
            Sans coder.
        </p>

        <div class="mt-10 rv d3">
            {{ buttons.primary('Je rejoins (147€)', checkout_url) }}
        </div>

    </div>
</section>

{# ════════════════════════════════════════════════════════════════
   SECTION 02 — RECONNAISSANCE (inversion ink-900, 80vh)
   Validation de la galère. Pas pour toi → si, pour toi.
   ════════════════════════════════════════════════════════════════ #}
<section class="bg-ink-900 text-cream-100 px-6 md:px-20"
         style="min-height: 80vh; display: flex; align-items: center; padding-top: 6rem; padding-bottom: 6rem;"
         aria-labelledby="reconnaissance-title">
    <div class="mx-auto text-center w-full" style="max-width: 720px;">

        <h2 id="reconnaissance-title" class="sr-only">Reconnaissance</h2>

        <p class="serif italic rv"
           style="font-size: clamp(1.75rem, 3.5vw, 2.5rem); line-height: 1.25;">
            Tu as testé ChatGPT deux ou trois fois.<br>
            Tu n'as pas su en faire un vrai outil de travail.
        </p>

        <p class="serif text-gold-300 mt-16 rv d1"
           style="font-size: clamp(1.5rem, 2.5vw, 1.75rem); line-height: 1.3;">
            C'est normal.
        </p>

        <p class="serif italic mt-16 rv d2"
           style="font-size: clamp(1.5rem, 3vw, 2rem); line-height: 1.3;">
            Les formations IA sont faites pour des marketers techniques.<br>
            Pas pour des consultantes qui facturent leur expertise.
        </p>

        <div class="mt-12 mb-12 flex justify-center">
            {% include 'components/_section_divider.html.twig' with { width: 60, animate: true } %}
        </div>

        <p class="serif italic rv d3 text-cream-100"
           style="font-size: clamp(1.5rem, 3vw, 2rem); line-height: 1.3;">
            Cette formation, elle est pour toi.
        </p>

    </div>
</section>

{# ════════════════════════════════════════════════════════════════
   SECTION 03 — PROMESSE 14 / 10 / 0 (70vh)
   Trois chiffres, trois colonnes. Le pacte tient en trois mots.
   ════════════════════════════════════════════════════════════════ #}
<section class="bg-cream-100 px-6 py-24 md:px-20 md:py-32"
         aria-labelledby="promesse-title">
    <div class="mx-auto" style="max-width: 1200px;">

        <p class="eyebrow-ds text-gold-500 text-center rv" data-centered>
            Le pacte · 14 jours
        </p>

        <h2 id="promesse-title"
            class="serif text-ink-900 text-center mt-6 rv d1"
            style="font-size: clamp(2.5rem, 5vw, 4rem); line-height: 1.05; font-weight: 400; letter-spacing: -0.01em;">
            Voici ce qui change.
        </h2>

        <div class="mt-20 grid gap-16 md:grid-cols-3 md:gap-12">

            <div class="text-center rv d1">
                <span class="chiffre-promesse">14</span>
                <p class="mt-4 font-mono uppercase tracking-[0.15em] text-ink-300"
                   style="font-size: 0.875rem;">jours</p>
                <p class="serif italic text-ink-700 mt-8" style="font-size: 1.125rem;">
                    À toi.
                </p>
            </div>

            <div class="text-center rv d2">
                <span class="chiffre-promesse">10</span>
                <p class="mt-4 font-mono uppercase tracking-[0.15em] text-ink-300"
                   style="font-size: 0.875rem;">heures par semaine</p>
                <p class="serif italic text-ink-700 mt-8" style="font-size: 1.125rem;">
                    Récupérées.
                </p>
            </div>

            <div class="text-center rv d3">
                <span class="chiffre-promesse">0</span>
                <p class="mt-4 font-mono uppercase tracking-[0.15em] text-ink-300"
                   style="font-size: 0.875rem;">ligne de code</p>
                <p class="serif italic text-ink-700 mt-8" style="font-size: 1.125rem;">
                    Tu n'écris jamais.
                </p>
            </div>

        </div>
    </div>
</section>

{# ════════════════════════════════════════════════════════════════
   SECTION 04 — LES 3 AGENTS (3 sub-articles)
   Sandra construit ses 3 agents pas à pas.
   ════════════════════════════════════════════════════════════════ #}
<section aria-labelledby="agents-title">

    <div class="bg-cream-100 px-6 pt-32 pb-16 md:px-20 md:pt-40 md:pb-20">
        <div class="mx-auto" style="max-width: 1200px;">
            <p class="eyebrow-ds text-gold-500 rv">
                La méthode · 03 agents
            </p>
            <h2 id="agents-title"
                class="serif text-ink-900 mt-6 rv d1"
                style="font-size: clamp(2.5rem, 5vw, 4rem); line-height: 1.05; font-weight: 400; letter-spacing: -0.01em; max-width: 900px;">
                Tu construis trois agents qui bossent pour toi.
            </h2>
        </div>
    </div>

    {# Agent 01 — L'Inbox · cream-100 #}
    <article class="bg-cream-100 px-6 py-24 md:px-20 md:py-32">
        <div class="mx-auto grid items-center gap-12 md:grid-cols-[45%_55%] md:gap-20" style="max-width: 1200px;">
            <div class="rv-l">
                <span class="numero-geant block">01</span>
                <h3 class="serif italic text-ink-900 mt-4"
                    style="font-size: clamp(2.5rem, 5vw, 3.5rem); line-height: 1.05;">
                    L'Inbox.
                </h3>
                <p class="mt-8 text-ink-300" style="font-size: 1.125rem; line-height: 1.6; max-width: 480px;">
                    Il trie tes emails, pré-rédige tes réponses, gère tes relances clients.
                </p>
                <p class="serif italic text-gold-500 mt-6"
                   style="font-size: clamp(1.25rem, 2vw, 1.5rem); line-height: 1.3;">
                    → 4 à 5 heures par semaine, récupérées.
                </p>
            </div>
            <div class="capture-claude-placeholder rv-r d1" aria-hidden="true">
                Capture Claude · Agent 01
            </div>
        </div>
    </article>

    {# Agent 02 — La Mission · cream-50 (alternance subtile, capture à gauche) #}
    <article class="bg-cream-50 px-6 py-24 md:px-20 md:py-32">
        <div class="mx-auto grid items-center gap-12 md:grid-cols-[55%_45%] md:gap-20" style="max-width: 1200px;">
            <div class="capture-claude-placeholder rv-l d1 order-2 md:order-1" aria-hidden="true">
                Capture Claude · Agent 02
            </div>
            <div class="rv-r order-1 md:order-2">
                <span class="numero-geant block">02</span>
                <h3 class="serif italic text-ink-900 mt-4"
                    style="font-size: clamp(2.5rem, 5vw, 3.5rem); line-height: 1.05;">
                    La Mission.
                </h3>
                <p class="mt-8 text-ink-300" style="font-size: 1.125rem; line-height: 1.6; max-width: 480px;">
                    Il écoute tes calls, sort tes comptes-rendus structurés, prépare la suite.
                </p>
                <p class="serif italic text-gold-500 mt-6"
                   style="font-size: clamp(1.25rem, 2vw, 1.5rem); line-height: 1.3;">
                    → 3 à 4 heures par semaine, récupérées.
                </p>
            </div>
        </div>
    </article>

    {# Agent 03 — La Propal · cream-100 #}
    <article class="bg-cream-100 px-6 py-24 md:px-20 md:py-32">
        <div class="mx-auto grid items-center gap-12 md:grid-cols-[45%_55%] md:gap-20" style="max-width: 1200px;">
            <div class="rv-l">
                <span class="numero-geant block">03</span>
                <h3 class="serif italic text-ink-900 mt-4"
                    style="font-size: clamp(2.5rem, 5vw, 3.5rem); line-height: 1.05;">
                    La Propal.
                </h3>
                <p class="mt-8 text-ink-300" style="font-size: 1.125rem; line-height: 1.6; max-width: 480px;">
                    Tu lui donnes cinq lignes de notes. Il te rend une proposition pro.
                </p>
                <p class="serif italic text-gold-500 mt-6"
                   style="font-size: clamp(1.25rem, 2vw, 1.5rem); line-height: 1.3;">
                    → 2 à 3 heures par semaine, récupérées.
                </p>
            </div>
            <div class="capture-claude-placeholder rv-r d1" aria-hidden="true">
                Capture Claude · Agent 03
            </div>
        </div>
    </article>

</section>

{# ════════════════════════════════════════════════════════════════
   SECTION 05 — RAMA (inversion ink-700, 80vh, faceless)
   Signature visuelle : monogramme R · S au lieu de portrait.
   ════════════════════════════════════════════════════════════════ #}
<section class="bg-ink-700 text-cream-100 px-6 py-24 md:px-20 md:py-32"
         style="min-height: 80vh; display: flex; align-items: center;"
         aria-labelledby="rama-title">
    <div class="mx-auto grid w-full items-center gap-12 md:grid-cols-[45%_55%] md:gap-20"
         style="max-width: 1200px;">

        {# Colonne gauche — monogramme faceless #}
        <div class="rv-l text-center md:text-left">
            <div class="monogramme-rs" aria-hidden="true">R<span class="text-gold-300 mx-2">·</span>S</div>
            <span class="sr-only">Rama Soumaré, formatrice IA</span>
            <div class="mt-6 md:mt-8 mx-auto md:mx-0" style="max-width: 80px;" aria-hidden="true">
                {% include 'components/_section_divider.html.twig' with { width: 80, centered: false, animate: true } %}
            </div>
        </div>

        {# Colonne droite — bio + email #}
        <div class="rv-r d1">
            <p class="eyebrow-ds text-gold-300">
                Ta formatrice
            </p>
            <h2 id="rama-title"
                class="serif italic text-cream-100 mt-6"
                style="font-size: clamp(2.5rem, 5vw, 4rem); line-height: 1.05; font-weight: 400;">
                Rama.
            </h2>

            <div class="serif italic text-cream-100 mt-8" style="font-size: clamp(1.25rem, 1.8vw, 1.375rem); line-height: 1.5;">
                <p>
                    Je suis formatrice et cofondatrice IA.
                    Mais surtout : je teste et je déploie chaque jour ce que je t'enseigne.
                </p>
                <p class="mt-6">
                    J'ai horreur du blabla. Ici, c'est 100% action ou rien.
                </p>
            </div>

            <div class="mt-10 mb-6">
                {% include 'components/_section_divider.html.twig' with { width: 60, centered: false } %}
            </div>

            <a href="mailto:hello@instant-ia.com"
               class="font-mono text-cream-100 hover:text-gold-300 transition"
               style="font-size: 1rem; letter-spacing: 0.05em;">
                hello@instant-ia.com
            </a>
        </div>

    </div>
</section>

{# ════════════════════════════════════════════════════════════════
   SECTIONS 06 → 09 — livrées en Phase C
   ════════════════════════════════════════════════════════════════ #}

{% endblock %}
