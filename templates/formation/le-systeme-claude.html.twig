{% include 'components/faq.html.twig' %}

{# ════════════════════════════════════════════════════════════════
   SECTION 09 — CTA FINAL (inversion ink-900, 80vh)
   La sortie de scroll. Une dernière fois la promesse + bouton.
   ════════════════════════════════════════════════════════════════ #}
<section class="bg-ink-900 text-cream-100 px-6 py-24 md:px-20 md:py-32"
         style="min-height: 80vh; display: flex; align-items: center;"
         aria-labelledby="cta-final-title">
    <div class="mx-auto text-center w-full" style="max-width: 720px;">

        <h2 id="cta-final-title"
            class="serif text-cream-100 rv"
            style="font-size: clamp(3rem, 7vw, 5rem); line-height: 1.05; font-weight: 400; letter-spacing: -0.02em;">
            14 jours.<br>
            Pour <em class="text-gold-400">transformer</em> Claude<br>
            en ton bras droit.
        </h2>

        <p class="serif italic text-gold-300 mt-12 rv d1"
           style="font-size: clamp(1.5rem, 2.5vw, 1.75rem);">
            C'est maintenant.
        </p>

        <div class="mt-12 flex justify-center rv d2">
            {{ buttons.primary('Je rejoins (147€)', checkout_url) }}
        </div>

        <p class="mt-10 text-cream-100 italic rv d3" style="font-size: 0.875rem; opacity: 0.75;">
            30 places fondateur. Après, c'est 297€.
        </p>

    </div>
</section>

{# ════════════════════════════════════════════════════════════════
   JSON-LD Schema.org Course — référencement Google enrichi
   Faceless : pas d'image instructor, pas d'attribut sameAs portrait.
   ════════════════════════════════════════════════════════════════ #}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "Course",
    "name": "Le Système Claude du Consultant",
    "description": "Formation Claude IA pour consultants et formateurs solo. 14 jours, 27 vidéos, 3 agents IA construits, méthode P.R.O.M.P.T.",
    "provider": {
